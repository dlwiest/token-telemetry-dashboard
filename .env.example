# Toggle providers on/off (auto-detected from local credentials if omitted)
# ENABLE_CLAUDE=true
# ENABLE_CODEX=true
# ENABLE_COPILOT=true

# Poll interval in seconds (default: 30, minimum: 5)
# POLL_INTERVAL=30

# Server port (default: 4800)
# PORT=4800

# Optional: override Claude Code credential discovery with an explicit OAuth token JSON
# CLAUDE_CODE_OAUTH_TOKEN={"accessToken":"...","refreshToken":"..."}
