{
  "name": "token-telemetry-dashboard",
  "description": "Wall-mountable dashboard showing remaining usage quotas for AI coding tools (Claude Code, OpenAI Codex, GitHub Copilot)",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "node --import tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.83.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.0"
  }
}
